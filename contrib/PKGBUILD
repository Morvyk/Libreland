# Maintainer: Morvyk <Morvyk@proton.me>
#
# Builds Libreland from its latest tagged GitHub release. For a build that
# tracks the git tip instead, use libreland-git (contrib/libreland-git/).
#
# Run `makepkg -si` from inside the directory holding this PKGBUILD (it needs
# libreland.install alongside it). Everything else is fetched from the release
# tarball — no local checkout required.

pkgname=libreland
pkgver=0.2.0
pkgrel=1
pkgdesc='A Wayland compositor in pure Rust, configured in Lua'
arch=('x86_64')
url='https://github.com/Morvyk/Libreland'
license=('MIT')
# Runtime libraries the binaries actually link (from DT_NEEDED): libgbm
# (mesa), libseat (seatd), libudev (systemd-libs), libinput, libxkbcommon,
# and libav* (ffmpeg) for media wallpapers. Lua is statically vendored and
# Wayland is pure-Rust, so neither is a dep. Xwayland is spawned and managed
# natively by default (config `xwayland = true`).
depends=(
    'glibc'
    'gcc-libs'
    'mesa'
    'libinput'
    'libxkbcommon'
    'seatd'
    'systemd-libs'
    'ffmpeg'
    'xorg-xwayland'
)
# `rust` provides cargo; the project's .cargo/config.toml links through mold.
# clang (libclang) + pkgconf build the ffmpeg-sys bindings (bindgen +
# pkg-config against the system ffmpeg).
makedepends=('rust' 'mold' 'clang' 'pkgconf')
optdepends=(
    'xdg-desktop-portal: desktop integration frontend (file dialogs, screen sharing)'
    'xdg-desktop-portal-wlr: screen sharing + screenshots via PipeWire'
    'xdg-desktop-portal-gtk: file chooser / settings / notification backend'
    'rofi: app launcher bound to Super+Space in the default config'
    'kitty: terminal bound to Super+Return in the default config'
)
provides=('libreland')
conflicts=('libreland-git')
install="$pkgname.install"
# Take full control of the build away from the user's /etc/makepkg.conf:
#  !lto   — the `release` profile already does fat LTO; makepkg's `lto`
#           would only inject -flto into the vendored-lua C build (mismatch).
#  !debug — the binary is built with debug=false + stripped, so there's no
#           debuginfo to split into a -debug package.
options=('!lto' '!debug')
# GitHub source tarball for the v$pkgver tag (extracts to Libreland-$pkgver/).
# SKIP: GitHub's auto-generated archive tarballs are not guaranteed to be
# byte-stable (they have changed compression and broken pinned checksums
# before), so a hardcoded sha256 is a liability, not a safeguard. The tag is
# the integrity anchor; transport is HTTPS.
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "$srcdir/Libreland-$pkgver"
    # makepkg.conf exports RUSTFLAGS (and the encoded variants), which would
    # *replace* — not merge with — the project's `.cargo/config.toml`
    # rustflags (the `-fuse-ld=mold` link arg). Unset them so config.toml +
    # the Cargo.toml `[profile.release]` (fat LTO, opt 3, strip) are the
    # single source of truth, regardless of the host's makepkg.conf.
    unset RUSTFLAGS CARGO_BUILD_RUSTFLAGS CARGO_ENCODED_RUSTFLAGS
    # The `release` profile already does fat LTO + symbol stripping; build
    # the whole workspace (compositor + output picker). --locked uses the
    # committed Cargo.lock so the package is reproducible. --workspace is
    # load-bearing: this workspace has a root package, so a bare `cargo
    # build` compiles only the compositor and package() then fails to
    # find the output-picker binary.
    cargo build --release --locked --workspace
}

package() {
    local root="$srcdir/Libreland-$pkgver"

    # Binaries.
    install -Dm755 "$root/target/release/libreland" \
        "$pkgdir/usr/bin/libreland"
    install -Dm755 "$root/target/release/libreland-output-picker" \
        "$pkgdir/usr/bin/libreland-output-picker"

    # Wayland session entry so display managers (SDDM/GDM/greetd/…) list
    # "Libreland". Exec is the bare compositor; it sets up its own session
    # identity (XDG_CURRENT_DESKTOP=libreland, etc.) on startup.
    install -Dm644 "$root/contrib/libreland.desktop" \
        "$pkgdir/usr/share/wayland-sessions/libreland.desktop"

    # Portal routing: xdg-desktop-portal selects this when
    # XDG_CURRENT_DESKTOP=libreland (which the compositor sets). Screen
    # capture/share goes to the wlr backend (Libreland's own screencopy),
    # everything else to the generic backend.
    install -Dm644 "$root/contrib/libreland-portals.conf" \
        "$pkgdir/usr/share/xdg-desktop-portal/libreland-portals.conf"

    # xdg-desktop-portal-wlr screencast chooser, scoped to Libreland
    # sessions (xdpw reads /etc/xdg/xdg-desktop-portal-wlr/$XDG_CURRENT_DESKTOP),
    # so it doesn't clobber another compositor's xdpw `config`. It points
    # the chooser at the libreland-output-picker installed above.
    install -Dm644 "$root/contrib/xdg-desktop-portal-wlr.config" \
        "$pkgdir/etc/xdg/xdg-desktop-portal-wlr/libreland"

    # License + docs.
    install -Dm644 "$root/LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 "$root/Documentation.md" "$pkgdir/usr/share/doc/$pkgname/Documentation.md"
}
