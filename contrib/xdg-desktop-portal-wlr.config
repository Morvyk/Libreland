# xdg-desktop-portal-wlr — screencast output chooser for Libreland.
#
# When an app starts a screen share, xdpw runs this chooser so you pick
# which output to capture. libreland-output-picker (a wlr-layer-shell
# overlay in this repo) dims every monitor, highlights + labels the one
# under the cursor, and prints its connector name (e.g. "DP-1") on click —
# which xdpw matches against its output list and captures via Libreland's
# zwlr_screencopy. Esc cancels.
#
# It replaces slurp, which crashes on this compositor: slurp 1.5.0 has an
# unguarded NULL deref in its wl_pointer.motion handler (no released fix).
#
# Install the picker, then point chooser_cmd at it:
#   cargo install --path output-picker      # -> ~/.cargo/bin/libreland-output-picker
#   chooser_cmd=libreland-output-picker      # (if ~/.cargo/bin is on PATH)
# or use an absolute path to the built binary, e.g.
#   chooser_cmd=/path/to/Libreland/target/release/libreland-output-picker
# Copy this file to ~/.config/xdg-desktop-portal-wlr/config.
[screencast]
chooser_type=simple
chooser_cmd=libreland-output-picker
