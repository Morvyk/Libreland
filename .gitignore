/target

# makepkg build artifacts (the PKGBUILD lives in contrib/, so its scratch
# dirs are created there — never at the repo root, where /src is the source)
/contrib/src/
/contrib/pkg/
/contrib/*.pkg.tar.*
/contrib/*.log

# Same for the standalone contrib sub-packages that carry their own PKGBUILD.
/contrib/*/src/
/contrib/*/pkg/
/contrib/*/*.pkg.tar.*
/contrib/*/*.log
# Compiled Vulkan layer object (built by its Makefile / PKGBUILD)
/contrib/no-present-timing-layer/*.so
